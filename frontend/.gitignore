# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# production
/build

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Capacitor native build artifacts ──────────────────────────────
# Keep source files (capacitor.config.ts, android/*/src) but ignore
# generated builds, caches and signing keys.
/android/build/
/android/.gradle/
/android/local.properties
/android/app/build/
/android/app/release/
/android/keystore.properties
/android/**/*.keystore
/android/.idea/

/ios/build/
/ios/Pods/
/ios/DerivedData/
/ios/App/Podfile.lock
/ios/.xcode.env.local
