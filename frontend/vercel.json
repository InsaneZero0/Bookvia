{
  "installCommand": "yarn install",
  "buildCommand": "CI=false yarn build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bookvia-production.up.railway.app/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://bookvia-production.up.railway.app/api/seo/sitemap.xml"
    }
  ]
}
