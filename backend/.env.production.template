# =============================================================================
# BOOKVIA - PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# ENVIRONMENT (REQUIRED)
# -----------------------------------------------------------------------------
# Options: development, staging, production
ENV=production

# Base URL for your domain (used in sitemap, emails, etc.)
# Include https:// but NO trailing slash
BASE_URL=https://bookvia.com

# -----------------------------------------------------------------------------
# DATABASE (REQUIRED)
# -----------------------------------------------------------------------------
# MongoDB connection string
# For Atlas: mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/

# Database name
DB_NAME=bookvia_prod

# -----------------------------------------------------------------------------
# SECURITY (REQUIRED)
# -----------------------------------------------------------------------------
# JWT secret - use a strong random string (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=your-secure-jwt-secret-minimum-32-characters

# CORS origins (comma-separated)
# Use specific domain in production
CORS_ORIGINS=https://bookvia.com,https://www.bookvia.com

# -----------------------------------------------------------------------------
# ADMIN ACCOUNT (REQUIRED)
# -----------------------------------------------------------------------------
# Initial admin account - will be created on first startup
ADMIN_EMAIL=admin@bookvia.com
ADMIN_INITIAL_PASSWORD=your-secure-admin-password

# -----------------------------------------------------------------------------
# SMS - TWILIO (OPTIONAL - mocked if not provided)
# -----------------------------------------------------------------------------
# Get credentials from: https://console.twilio.com/
# If not configured, SMS verification will be mocked (codes stored in DB)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# EMAIL - RESEND (OPTIONAL - mocked if not provided)
# -----------------------------------------------------------------------------
# Get API key from: https://resend.com/api-keys
# If not configured, emails will be mocked (stored in DB)
RESEND_API_KEY=re_...
FROM_EMAIL=Bookvia <noreply@bookvia.com>

# -----------------------------------------------------------------------------
# PAYMENTS - STRIPE (REQUIRED for bookings)
# -----------------------------------------------------------------------------
# Get keys from: https://dashboard.stripe.com/apikeys
# Use sk_live_... for production, sk_test_... for testing
STRIPE_API_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# CONFIGURATION BEHAVIOR
# =============================================================================
#
# ┌─────────────────┬───────────────────────────────────────────────────────┐
# │ Variable        │ Behavior                                              │
# ├─────────────────┼───────────────────────────────────────────────────────┤
# │ MONGO_URL       │ REQUIRED - App will not start without it              │
# │ DB_NAME         │ REQUIRED - App will not start without it              │
# │ JWT_SECRET      │ REQUIRED in production - must be secure               │
# │ TWILIO_*        │ Optional - auto-mocked if missing                     │
# │ RESEND_*        │ Optional - auto-mocked if missing                     │
# │ STRIPE_*        │ Optional - payments disabled if missing               │
# │ BASE_URL        │ Used for sitemap/emails - defaults to request host    │
# └─────────────────┴───────────────────────────────────────────────────────┘
#
# =============================================================================
